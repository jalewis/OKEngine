# OKEngine deployment overrides for ~/.hermes/config.yaml.
#
# Copy this file to a pack's .hermes-data/config.yaml, then fill the model,
# provider, token, and local endpoint placeholders for that deployment.
# The generated pack's docker-compose mounts ./.hermes-data at /opt/data and the
# pack root at /opt/vault inside the gateway container.

model:
  # Default for interactive sessions AND every cron lane that doesn't override it. Lanes CAN
  # override per job (extensions via `model:` in the manifest; engine/pack crons in the job
  # def) — point a cheap lane (glossary) at a free model and a reasoning lane (predictions
  # grading) at a strong one. Which model for which task: docs/model-selection.md.
  # Ships free-first: a capable free NVIDIA Nemotron (120B/12B-active MoE, 1M context).
  # All models here are OpenRouter — set OPENROUTER_API_KEY in the pack .env. A `:free` tier
  # is rate-limited, so the fallback chain below catches a rate-limit/error.
  default: nvidia/nemotron-3-super-120b-a12b:free
  provider: openrouter

# Fallback chain, in order, when the primary errors / is rate-limited / unreachable.
# Free OpenRouter tiers first, then a known PAID escape (deepseek) — used only when every
# free tier above is rate-limited. No openrouter/auto: it auto-routes to an unpredictable
# (possibly paid) model; a single explicit paid fallback is the controllable choice.
fallback_providers:
- provider: openrouter
  model: openai/gpt-oss-120b:free        # capable free workhorse (free tier)
- provider: openrouter
  model: nvidia/nemotron-3-nano-30b-a3b:free   # smaller/faster nemotron (free tier)
- provider: openrouter
  model: openrouter/free                 # Free Models Router — routes to ANY available free
                                         #   model (the free counterpart of openrouter/auto)
- provider: deepseek
  model: deepseek-v4-pro                 # PAID escape hatch — needs DEEPSEEK_API_KEY. Remove
                                         #   this entry for a strictly-free deployment (then a
                                         #   run fails if every free tier above is rate-limited).
# A local model (no rate limits) is the better paid-free workhorse if you have the hardware:
#   - {provider: custom, model: qwen3.5:27b, base_url: http://YOUR_OLLAMA_HOST:11434/v1}

compression:
  enabled: true
  threshold: 0.7
  target_ratio: 0.3
  protect_last_n: 20

terminal:
  # Required: the agent runs commands inside the gateway container so tools can see
  # the pack mounted at /opt/vault. cwd is the PAGE TREE (`/opt/vault/wiki`), NOT the
  # vault root — page writes go through the MCP write path (rooted at <vault>/wiki), so
  # a cwd at the vault root would make a stray relative `file_write` (e.g. `source/x`)
  # land at `/opt/vault/source` and fork from the canonical tree → split-brain vault
  # (okengine#110). Pinning cwd to the page tree keeps any relative write in the one tree.
  backend: local
  cwd: /opt/vault/wiki

plugins:
  # cron-plus is the scheduler the engine's whole cron fleet runs on — required
  # for the self-maintaining vault. `deploy.sh` (scripts/install-cron-plus.sh)
  # clones it into .hermes-data/plugins/cron-plus at the manifest-pinned commit
  # before the gateway starts. Add other installed plugins here as needed.
  enabled: [cron-plus]

mcp_servers:
  # Read-only OKEngine MCP query surface served by the okengine-mcp container.
  # The token MUST match the read server's: it falls back to the built-in
  # "okengine-local" when OKENGINE_MCP_TOKEN is unset, so that is the working
  # local default here. If you set OKENGINE_MCP_TOKEN in .env, ensure-runtime.sh
  # rewrites this header to match at deploy time (okengine#32).
  okengine:
    # Service name on the per-pack bridge — the gateway and okengine-mcp share the compose
    # default network, so this needs no host port and no port_offset (okengine#138). (A pre-#138
    # deployment used http://localhost:8730/mcp; ensure-runtime.sh rewrites that to this.)
    url: http://okengine-mcp:8730/mcp
    headers:
      Authorization: "Bearer okengine-local"

  # Enforced local write path. This stdio server runs inside the gateway image
  # and validates writes against the pack's nearest schema.yaml.
  okengine-write:
    command: /opt/hermes/.venv/bin/python
    args:
    - /opt/hermes/okengine-mcp/write_server.py

# Cron jobs opt into MCP explicitly. This keeps maintenance drains and pure
# script jobs from opening MCP connections unless a job requests them.
platform_toolsets:
  cron:
    - hermes-cron
    - no_mcp

# Agent-wide toolset hygiene. OKEngine agents curate the vault through the enforced MCP write
# path; they never run arbitrary code. `execute_code` is already runtime-blocked for cron jobs,
# but it still rides in via hermes-cron's includes, so agents waste turns reaching for a tool
# that is then refused. Disable it globally (defense-in-depth + no wasted turns).
agent:
  disabled_toolsets: [code_execution]
