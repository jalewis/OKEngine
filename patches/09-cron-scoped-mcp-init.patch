+def _discover_cron_mcp_tools(enabled_toolsets: list[str] | None) -> list[str]:
+    """Initialize only MCP servers admitted by this cron job's allowlist."""
+    from tools.mcp_tool import _load_mcp_config, register_mcp_servers
+
+    servers = _load_mcp_config()
+    if enabled_toolsets is None:
+        return register_mcp_servers(servers)
+    allowed = set(enabled_toolsets)
+    selected = {name: value for name, value in servers.items() if name in allowed}
+    omitted = len(servers) - len(selected)
+    if omitted:
+        logger.info(
+            "Cron MCP scope: initializing %d of %d configured server(s)",
+            len(selected), len(servers),
+        )
+    return register_mcp_servers(selected)
+
