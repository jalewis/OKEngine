+# ── Read-echo corruption guard ───────
+# A weak model sometimes echoes the gateway's line-numbered Read display back
+# into a write — "     12|content" (cat -n) or a "|---"/"|key:" pipe-prefixed
+# frontmatter (the display's column separator). That silently corrupts files
+# (a real corruption mode this guards against). Reject such writes so the model
+# rewrites clean content (the repair_broken_frontmatter cron is the safety net).
+_READ_ECHO_CATN_RE = re.compile(r"^\s*\d+\|")
+_READ_ECHO_PIPE_FM_RE = re.compile(r"^﻿?\|+(?:---|[A-Za-z_][\w-]*:)")
+
+
+def _detect_read_echo_corruption(content: str) -> Optional[str]:
+    """Return a rejection reason if ``content`` looks like Read-tool output
+    echoed back into a write (line-number or pipe-separator prefixes), else
+    None. Table-safe: a markdown body table (``| col |``) matches neither
+    pattern (cat-n needs ``<digits>|``; the pipe check needs ``|---`` or
+    ``|key:`` with no space, which a ``| col |`` row never has)."""
+    if not content:
+        return None
+    lines = content.split("\n")
+    catn = sum(1 for ln in lines[:80] if _READ_ECHO_CATN_RE.match(ln))
+    if catn >= 2:
+        return (f"content has {catn} lines prefixed with line numbers like '12|' — "
+                "that is Read-tool output echoed back into the write. Re-write the "
+                "file's ACTUAL content without the 'NN|' line-number prefixes.")
+    if lines and _READ_ECHO_PIPE_FM_RE.match(lines[0]):
+        return ("content opens with a pipe-prefixed frontmatter fence/key ('|---' or "
+                "'|type:') — the Read display's '|' column separator was echoed into "
+                "the write. Re-write clean frontmatter with no leading '|'.")
+    return None
+
+
+def _schema_reject(path: str, content: str) -> Optional[str]:
+    """OKF/domain schema gate (reads the vault's schema.yaml via tools.schema_validator).
+    Lazy-imported and fail-open: a validator/schema problem must never block a write —
+    only an actual conformance violation returns a reason."""
+    try:
+        from tools.schema_validator import schema_reject_reason
+        return schema_reject_reason(path, content)
+    except Exception:
+        return None
+
+
+_RESERVED_VAULT_FILES = {"log.md", "index.md", "agents.md", "hot.md", "readme.md",
+                         "health.md", "bundle.md"}
+
+
+def _reserved_file_reject(path: str) -> Optional[str]:
+    """The file tool must not be a weaker second write path around the enforced okengine-write MCP: a
+    cron agent carries BOTH, so this mirrors the write path's structural refusals for `.md` writes UNDER
+    the vault (WIKI_PATH) — non-vault file ops (logs, `_`-prefixed scripts) stay writable; fail-open on
+    any uncertainty (never block a legit write). Three refusals, matching write_server (invariant-audit
+    M12 + re-verify):
+      1. engine-managed reserved files (HOT/log/INDEX*/health/bundle/`_`/`.` — schema-EXEMPT, so
+         _schema_reject misses them);
+      2. PACK-declared `reserved_files` (else declaring a file reserved makes it MORE writable here);
+      3. a page whose current frontmatter is `status: tombstoned` (never resurrect — M18); a tombstoned
+         NORMAL page keeps its content slug, so a basename check alone cannot catch it."""
+    import os
+    if not path.lower().endswith(".md"):
+        return None
+    wiki = os.environ.get("WIKI_PATH")
+    if not wiki:
+        return None
+    try:
+        ap = os.path.realpath(path)
+        roots = [os.path.realpath(os.path.join(wiki, "wiki")), os.path.realpath(wiki)]
+        if not any(ap == r or ap.startswith(r + os.sep) for r in roots):
+            return None
+    except Exception:
+        return None
+    # basename from the RESOLVED target, not the raw path — a symlink 'innocent.md' -> 'HOT.md' must be
+    # judged by what it actually writes (re-verify).
+    base = os.path.basename(ap)
+    n = base.lower()
+    if n in _RESERVED_VAULT_FILES or n.startswith("index-") or base.startswith(("_", ".")):
+        return (f"'{path}' is an engine-managed structural/reserved vault file — not agent-writable "
+                "via the file tool. Curate the vault through the okengine-write MCP path (or hand-edit "
+                "out of band if a human change is truly intended).")
+    try:
+        from tools.schema_validator import reserved_files_for
+        if n in reserved_files_for(ap):
+            return (f"'{path}' is a pack-reserved file (schema reserved_files) — not agent-writable "
+                    "via the file tool.")
+    except Exception:
+        pass
+    try:
+        if os.path.isfile(ap):
+            import re as _re
+            with open(ap, "r", encoding="utf-8", errors="replace") as _fh:
+                _head = _fh.read(1000000)   # whole page: a heavily-cited entity's frontmatter can
+                                            # exceed 4KB, and _tombstone() preserves the full fm — a
+                                            # truncated read would miss the closing fence and fail open
+            _fm = _re.match(r"^\ufeff?---\r?\n(.*?)\r?\n---", _head, _re.DOTALL)
+            if _fm and _re.search(r"(?im)^status:\s*[\"']?tombstoned\b", _fm.group(1)):
+                return (f"'{path}' is tombstoned — not agent-writable via the file tool; write to its "
+                        "successor (superseded_by) or use the okengine-write tombstone tool.")
+    except Exception:
+        pass
+    return None
+
