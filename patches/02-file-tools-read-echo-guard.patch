+# Detection regex for the file_read tool's "LINE_NUM|CONTENT" output format.
+# Matches leading whitespace + digits + literal pipe.
+_READ_LINE_PREFIX_RE = re.compile(r"^\s*\d+\|")
+
+
+def _looks_like_line_numbered_read_output(content: str) -> bool:
+    """Return True when the write content carries the file_read line-number
+    prefix on most lines — the model has done a naive read-modify-write
+    and is about to bake `     1|---\\n     2|type: vendor\\n...` into the
+    file, which silently breaks every YAML/JSON/Python parser downstream.
+
+    Heuristic:
+      * For short writes (<=4 non-empty lines): require ALL lines to match
+        (a 1-2-line snippet that happens to start with a number+pipe is too
+        ambiguous to block).
+      * For longer writes: require >50% of non-empty lines to match. A
+        legitimate file might have a stray `12|` somewhere, but Read-format
+        corruption hits ~every line.
+
+    Source of the corruption: file_read returns content as
+    `LINE_NUM|CONTENT` per its tool description (file_tools.py:1031).
+    Agents are expected to strip the prefix before writing back; some
+    don't. Caught after 54 entity pages were silently broken in the
+    vault (e.g. by cron agents), making them invisible to wake-gates
+    that filter by `type:` frontmatter.
+    """
+    if not isinstance(content, str) or not content.strip():
+        return False
+    lines = [ln for ln in content.split("\n") if ln.strip()]
+    if not lines:
+        return False
+    matches = sum(1 for ln in lines if _READ_LINE_PREFIX_RE.match(ln))
+    if matches == 0:
+        return False
+    if len(lines) <= 4:
+        return matches == len(lines)
+    return matches / len(lines) > 0.5
+
+
+def _doubled_path_segment(path_str: str) -> str | None:
+    """Return the doubled segment if the resolved write path contains the
+    same directory name back-to-back (e.g. `/vault/wiki/wiki/index.md`).
+
+    This is the agent-CWD-confusion footgun: the model thinks CWD is X
+    and writes `wiki/foo.md`, but the actual CWD is `X/wiki`, so the
+    file lands at `X/wiki/wiki/foo.md`. Once a rogue `wiki/wiki/` exists,
+    every dataview / find_vault_root walker that checks for a `wiki/`
+    subdir matches the rogue first, silently breaking downstream pipelines.
+
+    Caught after `wiki/wiki/index.md` (and rogue `./concepts/`, `./sources/`
+    at vault root) was created by cron agents — the
+    competitive-landscape PDF rendered with empty dashboard tables
+    because find_vault_root walked into `wiki/wiki/` and load_entities
+    found nothing.
+
+    Returns the doubled segment string for the error message, or None if
+    no doubling detected. Skips standard non-directory parts ('/', '.', '..').
+    """
+    try:
+        parts = Path(path_str).resolve().parts
+    except (OSError, ValueError):
+        return None
+    skip = {"/", ".", ".."}
+    for i in range(len(parts) - 1):
+        a = parts[i]
+        if a in skip or a.startswith("."):
+            continue
+        if a == parts[i + 1]:
+            return f"{a}/{a}"
+    return None
+
+
