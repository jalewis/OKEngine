@@ -201,6 +201,39 @@ def _list_registered_web_providers():
         return []
 
 
+# okengine (issue #190): opt-in round-robin across the AVAILABLE web-search backends. Set
+# `web.backend: rotate` to spread load across providers (e.g. Tavily + Exa + a plugin backend)
+# instead of pinning one, so no single free tier gets rate-limited. Availability resolves through
+# _is_backend_available (the upstream chokepoint) for the built-ins and through the
+# web_search_registry for plugin providers, so a registered provider (e.g. serper) joins the
+# rotation automatically — no hardcoded list to maintain. Config is read live per call and the
+# counter advances per call. Additive: any other value / unset is unchanged.
+_OKENGINE_ROTATE_I = -1
+# xai deliberately excluded: its availability probe may hold OAuth state and it is a paid,
+# non-rate-limited tier — rotation exists to spread FREE-tier load.
+_OKENGINE_ROTATE_LEGACY_ORDER = (
+    "tavily", "exa", "parallel", "firecrawl", "searxng", "brave-free", "ddgs")
+
+
+def _okengine_rotate_backend() -> str:
+    """Next available web backend, round-robin; normal single-pick order if none."""
+    global _OKENGINE_ROTATE_I
+    avail = [b for b in _OKENGINE_ROTATE_LEGACY_ORDER if _is_backend_available(b)]
+    for provider in _list_registered_web_providers():
+        name = getattr(provider, "name", "")
+        if not name or name == "xai" or name in _LEGACY_WEB_BACKENDS or name in avail:
+            continue
+        try:
+            if provider.is_available():
+                avail.append(name)
+        except Exception:  # noqa: BLE001 — a broken provider is skipped
+            continue
+    if not avail:
+        return "firecrawl"
+    _OKENGINE_ROTATE_I = (_OKENGINE_ROTATE_I + 1) % len(avail)
+    return avail[_OKENGINE_ROTATE_I]
+
+
 def _get_backend() -> str:
