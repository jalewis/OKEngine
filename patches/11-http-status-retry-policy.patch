diff --git a/agent/agent_init.py b/agent/agent_init.py
index 7bf75c9..5cf381c 100644
--- a/agent/agent_init.py
+++ b/agent/agent_init.py
@@ -1497,6 +1497,31 @@ def init_agent(
         _api_retries = 3
     agent._api_max_retries = _api_retries
 
+    # Optional endpoint-specific HTTP attempt/fallback contract. Keys are
+    # status-code strings; values accept max_attempts and fallback. The loop
+    # ceiling permits a 503 policy to exceed the generic retry budget while
+    # each status still terminates at its own bound.
+    _raw_http_policy = _agent_section.get("http_status_policy", {})
+    if not isinstance(_raw_http_policy, dict):
+        _raw_http_policy = {}
+    _http_policy = {}
+    _retry_ceiling = _api_retries
+    for _status, _rule in _raw_http_policy.items():
+        if not isinstance(_rule, dict):
+            continue
+        try:
+            _status_key = str(int(_status))
+            _attempts = max(1, int(_rule.get("max_attempts", _api_retries)))
+        except (TypeError, ValueError):
+            continue
+        _http_policy[_status_key] = {
+            "max_attempts": _attempts,
+            "fallback": bool(_rule.get("fallback", True)),
+        }
+        _retry_ceiling = max(_retry_ceiling, _attempts)
+    agent._http_status_policy = _http_policy
+    agent._api_retry_loop_ceiling = _retry_ceiling
+
     # Initialize context compressor for automatic context management
     # Compresses conversation when approaching model's context limit
     # Configuration via config.yaml (compression section)
