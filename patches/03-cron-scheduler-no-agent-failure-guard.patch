+# Toolsets stripped from a cron agent that only runs to REPORT a failed
+# data-collection script. Such a run exists solely to summarize an error that
+# is already in its prompt — it has no business mutating the vault. Names map
+# to CONFIGURABLE_TOOLSETS keys: terminal/process exec, file write+patch, and
+# arbitrary code execution. (Incident 2026-06-14: a script-failure agent ran
+# `rm` and deleted dashboards while "reporting" the error.)
+_FAILURE_PATH_BLOCKED_TOOLSETS = ("terminal", "file", "code_execution")
+
+
+def _apply_failure_path_toolset_guard(disabled: list[str], script_failed: bool) -> list[str]:
+    """When the agent only woke to report a script failure, append the mutating
+    toolsets to the always-wins denylist so the report run cannot delete, write,
+    patch, or shell out. No-op (returns the list unchanged) on every normal run,
+    including legitimate ``wakeAgent: true`` runs that need full tools."""
+    if not script_failed:
+        return disabled
+    out = list(disabled)
+    for name in _FAILURE_PATH_BLOCKED_TOOLSETS:
+        if name not in out:
+            out.append(name)
+    return out
+
+
