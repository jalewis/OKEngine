diff --git a/gateway/platforms/api_server.py b/gateway/platforms/api_server.py
index 1e4ad4c3a..218769174 100644
--- a/gateway/platforms/api_server.py
+++ b/gateway/platforms/api_server.py
@@ -1106,7 +1106,31 @@ class APIServerAdapter(BasePlatformAdapter):
 
         runtime_kwargs = _resolve_runtime_agent_kwargs()
         reasoning_config = GatewayRunner._load_reasoning_config()
-        model = _resolve_gateway_model()
+        # okengine#151b: pin the api_server's inference model/provider independently of the gateway
+        # default. A deployment may set the default to a cheap/bulk model on a local host for ingest
+        # crons; the interactive chat is a reasoning+tools task that wants a reliable, capable model.
+        #   API_SERVER_INFERENCE_PROVIDER  re-resolves credentials for a named provider (e.g.
+        #                                  "deepseek") so chat can use a cloud model unaffected by
+        #                                  local-host load; empty -> the gateway default provider.
+        #   API_SERVER_INFERENCE_MODEL     pins the model id (resolved on the chosen provider/host);
+        #                                  empty -> the gateway default model.
+        _inf_provider = os.getenv("API_SERVER_INFERENCE_PROVIDER", "").strip()
+        if _inf_provider:
+            from hermes_cli.runtime_provider import resolve_runtime_provider
+            try:
+                _inf_rt = resolve_runtime_provider(requested=_inf_provider)
+                # Copy only the credential keys already present in runtime_kwargs (provider,
+                # base_url, api_key, …). resolve_runtime_provider() also returns resolver-only
+                # metadata (e.g. 'source') that AIAgent.__init__ does not accept, so a wholesale
+                # replace would raise "unexpected keyword argument".
+                for _k in list(runtime_kwargs.keys()):
+                    if _k in _inf_rt:
+                        runtime_kwargs[_k] = _inf_rt[_k]
+            except Exception as _inf_exc:
+                logger.warning(
+                    "api_server: inference provider override %r failed (%s); using default provider",
+                    _inf_provider, _inf_exc)
+        model = os.getenv("API_SERVER_INFERENCE_MODEL", "").strip() or _resolve_gateway_model()
 
         # When the primary provider's auth fails (expired token / 429 quota
         # cap), _resolve_runtime_agent_kwargs() falls through to the fallback
